# ---- Gradle ----
.gradle/
build/
out/
classes/
bin/

# Gradle wrapper: keep the wrapper itself tracked, ignore local launcher noise
!gradle/wrapper/gradle-wrapper.jar

# ---- ForgeGradle / MinecraftForge ----
# Decompiled/processed Minecraft + generated run artifacts
run/
run-data/
runs/
# Generated data (uncomment to track data-gen output instead)
# src/generated/

# ---- IntelliJ IDEA ----
.idea/
*.iml
*.ipr
*.iws
.idea_modules/

# ---- Eclipse ----
.eclipse/
.metadata/
.settings/
.classpath
.project
*.launch
.apt_generated/
.factorypath

# ---- VS Code ----
.vscode/

# ---- NetBeans ----
nbproject/
build.xml

# ---- OS noise ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Java / JVM ----
*.class
hs_err_pid*
replay_pid*
*.log

# ---- Local / secrets ----
# Never commit auth tokens or local overrides
*.local
local.properties
synapse-client.toml

# ---- Internal-only (not part of the buildable public source) ----
# Design docs / planning notes live locally but are kept out of the public repo.
refs/

# ---- Dev-only test mods (not part of the shipped/buildable public mod) ----
# Third-party mod jars used only to exercise Synapse locally, and the gradle
# script that declares them. A clean clone has neither, so it builds with the
# minimum dependency set (the apply-from in build.gradle is a no-op).
libs/
dev-mods.gradle

# ---- MCP companion (Node) ----
# build/ above already covers mcp/build/. Ignore deps + the local smoke test.
node_modules/
mcp/test-client.mjs

# Stray source-tree zip some local tool keeps creating
*.zip
